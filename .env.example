# Node
TZ=UTC
PORT=3333
HOST=127.0.0.1
NODE_ENV=development

# App
LOG_LEVEL=info
APP_KEY=                          # Generate dengan: node ace generate:key
APP_URL=http://${HOST}:${PORT}

# Session
SESSION_DRIVER=cookie

#--------------------------------------------------------------------
# CORS (configure allowed origins for API access)
#--------------------------------------------------------------------
# CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Database (MySQL via Docker)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=super_user
DB_PASSWORD=1141140203
DB_DATABASE=madtsanda_platform_database

# Drive / File Storage (RustFS / S3-compatible)
DRIVE_DISK=s3
S3_KEY=super_user
S3_SECRET=1141140203
S3_BUCKET=madtsanda-platform-storage
S3_REGION=us-east-1
S3_ENDPOINT=http://127.0.0.1:9000

# Rate Limiter
LIMITER_STORE=redis

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=12345678
REDIS_DB=0